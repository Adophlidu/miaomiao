[Unit]
Description=miaomiao Hono API server
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=ec2-user
EnvironmentFile=/opt/miaomiao/server.env
ExecStart=/usr/bin/node /opt/miaomiao/server/index.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
